mixed_array = ['f', '1', 'b', '2', 'c', '3', 'd', '4', '2.5']

letters = []  #  буквы
numbers = []  #  числа

for item in mixed_array:
    try:
        num = float(item)
        numbers.append(num)
    except ValueError:
        letters.append(item)
# Вывод
print("Буквы:", letters)
print("Числа:", numbers)
